<Page x:Class="UnoEdit.Skia.Desktop.RuntimeTestsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:runtimetests="using:Uno.UI.RuntimeTests">
  <!--
    This page hosts the Uno RuntimeTests engine control.
    It is navigated to automatically when the env var
    UNO_RUNTIME_TESTS_RUN_TESTS is set (CI headless mode).
    Tests write results to UNO_RUNTIME_TESTS_OUTPUT_PATH.
  -->
  <runtimetests:UnitTestsControl />
</Page>
