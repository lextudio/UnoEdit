<Project Sdk="Uno.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0-desktop</TargetFramework>
    <RootNamespace>LeXtudio.UI.Text.Core</RootNamespace>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Authors>LeXtudio</Authors>
    <Company>LeXtudio</Company>
    <Version>1.0.0</Version>
    <Description>Core cross-platform text/IME primitives used by editor integrations.</Description>
    <PackageId>LeXtudio.UI.Text.Core</PackageId>
    <IsPackable>true</IsPackable>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <Deterministic>true</Deterministic>
    <ContinuousIntegrationBuild Condition="'$(CI)' == 'true'">true</ContinuousIntegrationBuild>
  </PropertyGroup>

  <PropertyGroup Condition="'$(OS)' == 'Unix' and Exists('/System/Library/Frameworks/AppKit.framework')">
    <TextCoreMacInputSource>$(MSBuildProjectDirectory)/Native/MacOS/UnoEditMacInput.mm</TextCoreMacInputSource>
    <TextCoreMacInputOutput>$(MSBuildProjectDirectory)/bin/$(Configuration)/$(TargetFramework)/libUnoEditMacInput.dylib</TextCoreMacInputOutput>
    <GetCopyToOutputDirectoryItemsDependsOn>$(GetCopyToOutputDirectoryItemsDependsOn);AddTextCoreMacBridgeToCopyItems</GetCopyToOutputDirectoryItemsDependsOn>
  </PropertyGroup>

  <PropertyGroup>
    <MacImeDylibPath Condition="Exists('$(TextCoreMacInputOutput)')">$(TextCoreMacInputOutput)</MacImeDylibPath>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
    <None Include="buildTransitive/LeXtudio.UI.Text.Core.targets" Pack="true" PackagePath="buildTransitive/LeXtudio.UI.Text.Core.targets" />
  </ItemGroup>

  <ItemGroup Condition="'$(MacImeDylibPath)' != ''">
    <None Include="$(MacImeDylibPath)" Pack="true" PackagePath="runtimes/osx/native/libUnoEditMacInput.dylib" />
    <None Include="$(MacImeDylibPath)" Pack="true" PackagePath="runtimes/osx-x64/native/libUnoEditMacInput.dylib" />
    <None Include="$(MacImeDylibPath)" Pack="true" PackagePath="runtimes/osx-arm64/native/libUnoEditMacInput.dylib" />
  </ItemGroup>

  <Target Name="EnsureMacNativeBridgeForPack" BeforeTargets="Pack">
    <Message Importance="high" Text="[LeXtudio.UI.Text.Core] macOS native bridge path: $(MacImeDylibPath)" Condition="'$(MacImeDylibPath)' != ''" />
    <Error
      Condition="'$(OS)' == 'Unix' and Exists('/System/Library/Frameworks/AppKit.framework') and '$(MacImeDylibPath)' == ''"
      Text="macOS packaging requires libUnoEditMacInput.dylib. Build src/LeXtudio.UI.Text.Core/LeXtudio.UI.Text.Core.csproj first so the dylib is produced." />
  </Target>

  <Target Name="BuildTextCoreMacInputBridge"
          AfterTargets="Build"
          Condition="'$(OS)' == 'Unix' and Exists('/System/Library/Frameworks/AppKit.framework') and Exists('$(TextCoreMacInputSource)')">
    <Message Importance="high" Text="[LeXtudio.UI.Text.Core] Building native macOS IME bridge: $(TextCoreMacInputOutput)" />
    <Exec Command="xcrun clang++ -dynamiclib -fobjc-arc -framework AppKit -framework Foundation -o &quot;$(TextCoreMacInputOutput)&quot; &quot;$(TextCoreMacInputSource)&quot;" />
  </Target>

  <Target Name="AddTextCoreMacBridgeToCopyItems"
          DependsOnTargets="BuildTextCoreMacInputBridge"
          Condition="'$(OS)' == 'Unix' and Exists('/System/Library/Frameworks/AppKit.framework') and Exists('$(TextCoreMacInputOutput)')">
    <ItemGroup>
      <ContentWithTargetPath Include="$(TextCoreMacInputOutput)">
        <TargetPath>libUnoEditMacInput.dylib</TargetPath>
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </ContentWithTargetPath>
    </ItemGroup>
  </Target>
</Project>
