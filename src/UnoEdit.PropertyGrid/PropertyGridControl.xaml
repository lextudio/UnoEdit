<UserControl
    x:Class="UnoEdit.PropertyGrid.PropertyGridControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:UnoEdit.PropertyGrid">

    <Grid RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ComboBox x:Name="CategoryComboBox"
                  HorizontalAlignment="Stretch"
                  SelectionChanged="OnCategoryChanged"
                  PlaceholderText="All Properties" />

        <ScrollViewer Grid.Row="1">
            <ItemsControl x:Name="PropertiesItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="local:PropertyItemViewModel">
                        <Grid ColumnSpacing="8" Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Bind PropertyName}"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       Opacity="0.8" />
                            <local:PropertyEditorControl Grid.Column="1"
                                                         ViewModel="{x:Bind}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
