<Window
    x:Class="UnoEdit.WinUI.Sample.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:editor="using:UnoEdit.WinUI.Controls"
    Title="UnoEdit WinUI 3 Sample">
    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Grid Grid.Row="0" Padding="12,8" Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="2">
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="UnoEdit WinUI 3 Sample" />
                <TextBlock FontSize="12" Opacity="0.7" Text="Backed by the UnoEdit document model — TextDocument, highlighting, folding." />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <ComboBox x:Name="SyntaxComboBox"
                          MinWidth="140"
                          PlaceholderText="Syntax highlighting"
                          SelectionChanged="OnSyntaxChanged" />
                <ToggleButton x:Name="ThemeButton"
                              Content="☀ Light"
                              Click="OnThemeButtonClick" />
            </StackPanel>
        </Grid>

        <!-- Stats bar -->
        <Border Grid.Row="1"
                Padding="12,4"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
            <TextBlock x:Name="StatsText"
                       FontFamily="Consolas"
                       FontSize="12"
                       Text="Ready" />
        </Border>

        <!-- Editor -->
        <editor:TextEditor x:Name="Editor"
                           Grid.Row="2"
                           TextChanged="OnEditorTextChanged" />

        <!-- Status bar -->
        <Border Grid.Row="3"
                Padding="12,4"
                Background="{ThemeResource LayerFillColorDefaultBrush}">
            <TextBlock x:Name="StatusText"
                       FontSize="12"
                       Opacity="0.7"
                       Text="UnoEdit document model running." />
        </Border>
    </Grid>
</Window>
