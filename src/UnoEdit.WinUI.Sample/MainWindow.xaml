<Window
    x:Class="UnoEdit.WinUI.Sample.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:editor="using:UnoEdit.WinUI.Controls"
    xmlns:pg="using:UnoEdit.PropertyGrid"
    Title="UnoEdit WinUI 3 Sample">
    <Grid Padding="20" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header: title + toolbar (matches Uno sample layout) -->
        <StackPanel Spacing="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="2">
                    <TextBlock FontSize="28"
                               FontWeight="SemiBold"
                               Text="UnoEdit Desktop Bootstrap" />
                    <TextBlock Opacity="0.72"
                               Text="This host is using the portable UnoEdit document core from the ported AvalonEdit model." />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <ComboBox x:Name="HighlighterComboBox"
                              SelectionChanged="OnHighlighterChanged">
                        <ComboBoxItem Content="TextMate" />
                        <ComboBoxItem Content="XSHD" />
                        <ComboBoxItem Content="None" />
                    </ComboBox>
                    <Button x:Name="FindButton"
                            Content="Find"
                            Click="OnFindClick" />
                    <Button x:Name="CompleteButton"
                            Content="Complete"
                            Click="OnCompleteClick" />
                    <ToggleButton x:Name="ThemeToggle"
                                  Content="&#x2600; Light"
                                  Click="OnThemeToggleClick" />
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Stats bar -->
        <Border Grid.Row="1"
                Padding="12"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <TextBlock x:Name="StatsTextBlock"
                       AutomationProperties.AutomationId="StatsTextBlock"
                       FontFamily="Consolas"
                       TextWrapping="WrapWholeWords" />
        </Border>

        <!-- Editor + Property panel -->
        <Grid Grid.Row="2" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <editor:TextEditor x:Name="Editor"
                               AutomationProperties.AutomationId="MainEditor" />

            <!-- Property panel -->
            <Grid Grid.Column="1" RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <ComboBox x:Name="PropertyObjectComboBox"
                          HorizontalAlignment="Stretch"
                          SelectionChanged="OnPropertyObjectChanged">
                    <ComboBoxItem Content="TextEditor" />
                    <ComboBoxItem Content="TextArea" />
                    <ComboBoxItem Content="Options" />
                </ComboBox>
                <pg:PropertyGridControl x:Name="PropertyGrid"
                                        Grid.Row="1" />
            </Grid>
        </Grid>
    </Grid>
</Window>
