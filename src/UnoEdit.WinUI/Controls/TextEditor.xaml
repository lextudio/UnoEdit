<UserControl
    x:Class="UnoEdit.WinUI.Controls.TextEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:UnoEdit.WinUI.Controls">
    <Border x:Name="EditorBorder" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Inline search bar (hidden until OpenSearchPanel) -->
            <Border x:Name="PART_SearchBar"
                    Grid.Row="0"
                    Visibility="Collapsed"
                    Padding="8,6"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PART_SearchBox"
                             Grid.Column="0"
                             PlaceholderText="Find&#x2026;"
                             KeyDown="OnSearchBoxKeyDown"
                             TextChanged="OnSearchTextChanged" />
                    <TextBlock x:Name="PART_SearchStatus"
                               Grid.Column="1"
                               VerticalAlignment="Center"
                               MinWidth="64"
                               Margin="8,0"
                               Opacity="0.7" />
                    <Button Grid.Column="2"
                            Content="&#x25B2;"
                            Padding="8,4"
                            ToolTipService.ToolTip="Previous match (Shift+F3)"
                            Click="OnFindPrevClick" />
                    <Button Grid.Column="3"
                            Content="&#x25BC;"
                            Padding="8,4"
                            ToolTipService.ToolTip="Next match (F3)"
                            Click="OnFindNextClick" />
                    <Button Grid.Column="4"
                            Content="&#x2715;"
                            Padding="8,4"
                            Click="OnCloseSearchClick" />
                </Grid>
            </Border>

            <!-- Main editing TextBox -->
            <TextBox x:Name="PART_EditBox"
                     Grid.Row="1"
                     AcceptsReturn="True"
                     BorderThickness="0"
                     Padding="8"
                     FontFamily="Consolas"
                     FontSize="14"
                     IsSpellCheckEnabled="False"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap"
                     KeyDown="OnEditBoxKeyDown"
                     SelectionChanged="OnEditBoxSelectionChanged"
                     TextChanged="OnEditBoxTextChanged" />
        </Grid>
    </Border>
</UserControl>
