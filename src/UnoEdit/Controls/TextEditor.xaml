<!-- WinUI 3 shell for the unified TextEditor control.
     Uses the same UnoEdit.Skia.Desktop.Controls rendering pipeline. -->
<UserControl
    x:Class="UnoEdit.Skia.Desktop.Controls.TextEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:UnoEdit.Skia.Desktop.Controls">
    <Border x:Name="EditorBorder"
            Padding="1"
            BorderBrush="{ThemeResource UnoEditorBorderBrush}"
            BorderThickness="{StaticResource UnoTextEditorBorderThickness}"
            CornerRadius="{StaticResource UnoTextEditorCornerRadius}"
            Background="{ThemeResource UnoEditorBackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <controls:SearchPanel x:Name="PART_SearchPanel"
                                  Grid.Row="0"
                                  Grid.RowSpan="2"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Top"
                                  Canvas.ZIndex="10"
                                  Visibility="Collapsed" />

            <controls:TextArea x:Name="PART_TextArea"
                               AutomationProperties.AutomationId="TextArea"
                               Grid.Row="1" />
        </Grid>
    </Border>
</UserControl>
