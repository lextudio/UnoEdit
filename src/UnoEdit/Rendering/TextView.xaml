<!-- Uno equivalent of avalonedit/ICSharpCode.AvalonEdit/Rendering/TextView.xaml
     Keep in sync with the WPF version when making structural changes. -->
<UserControl x:Class="ICSharpCode.AvalonEdit.Rendering.TextView"
             x:Name="RootControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:UnoEdit.Skia.Desktop.Controls"
             xmlns:folding="using:ICSharpCode.AvalonEdit.Folding"
             KeyDown="OnRootKeyDown"
             PointerPressed="OnRootPointerPressed"
             PointerMoved="OnRootPointerMoved"
             PointerReleased="OnRootPointerReleased">
  <!--
    Background="#01000000" = nearly transparent but still hit-testable in Uno Skia.
    Pure Transparent receives no pointer events in Skia renderer.
    Keyboard events and pointer events are all on the UserControl so that
    CapturePointer / ReleasePointerCapture happen on the same element that
    receives the captured PointerReleased event.
  -->
  <Border x:Name="RootBorder"
          Background="#01000000"
          IsTabStop="True"
          AutomationProperties.Name="Code editor"
          AutomationProperties.AutomationId="CodeEditorBorder">
    <ScrollViewer x:Name="TextScrollViewer"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto"
                  ViewChanged="OnScrollViewerViewChanged">
      <StackPanel x:Name="ContentStackPanel"
                  VerticalAlignment="Top">
        <Border x:Name="TopSpacer" Height="0" />

        <Grid x:Name="EditorGrid">
          <Grid.ColumnDefinitions>
            <!--
              LineNumberColumn: shown/hidden by ShowLineNumbers.
              FoldMarginColumn: always visible (mirrors AvalonEdit where FoldingMargin
                                stays in LeftMargins independently of ShowLineNumbers).
              TextColumn: text content with a small left gap.
            -->
            <ColumnDefinition x:Name="LineNumberColumn" Width="0" />
            <ColumnDefinition x:Name="FoldMarginColumn" Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <!--
            Line-number margin. Line numbers are drawn by a CanvasControl (inserted in code-behind),
            mirroring AvalonEdit's LineNumberMargin which renders numbers directly rather than via a
            per-line control. Visibility/width toggled by ShowLineNumbers in code-behind.
          -->
          <Grid x:Name="LineNumberHost" Width="40" Visibility="Collapsed" />

          <!--
            Fold-marker margin. Always visible regardless of ShowLineNumbers.
            Width=16 for the fold glyph.
          -->
          <!--
            Fold margin. Markers + connecting lines are drawn by a CanvasControl (inserted in
            code-behind), like AvalonEdit's FoldingMargin.OnRender. Toggling a fold is handled by
            coordinate hit-testing in the pointer handler (TryToggleFoldAtViewportPoint), so no
            per-marker UIElement is needed — which keeps fold rows at exactly LineHeight.
          -->
          <Grid x:Name="FoldMarginHost" Grid.Column="1" Width="16" />

          <!-- Text content column -->
          <Grid Grid.Column="2" x:Name="TextContentGrid">
            <!-- Background-highlight overlay (bracket match, reference markers). Behind text,
                 scrolls with content; positioned in content space by the AvalonEdit pipeline. -->
            <Canvas x:Name="BackgroundHighlightCanvas" IsHitTestVisible="False" />

            <!-- Editor text, caret, selection and line highlights are all drawn by the
                 CanvasControl text surface (inserted in code-behind), mirroring AvalonEdit's
                 TextView.OnRender. There is intentionally no per-line ItemsControl. -->

            <!-- Overlay for inline UIElements created by InlineObjectRun -->
            <Canvas x:Name="InlineObjectsCanvas" IsHitTestVisible="True" />
          </Grid>

          <!--
            Cheap overlay layer spanning all columns: current-line highlight, selection, caret and
            preedit underline (rectangles only — no glyph shaping). Drawing these on their own
            CanvasControl (inserted in code-behind) lets selection drag redraw just this layer while
            the expensive glyph/line-number surfaces stay untouched — the AvalonEdit selection/caret
            layer split.
          -->
          <Grid x:Name="OverlayHost" Grid.Column="0" Grid.ColumnSpan="3" IsHitTestVisible="False" />
        </Grid>

        <Border x:Name="BottomSpacer" Height="0" />

        <!-- Live-region announcer for screen readers: updates when folds toggle -->
        <TextBlock x:Name="LiveRegionAnnouncer"
                   Opacity="0"
                   IsHitTestVisible="False"
                   AutomationProperties.AutomationId="LiveRegionAnnouncer" />
      </StackPanel>
    </ScrollViewer>
  </Border>
</UserControl>
