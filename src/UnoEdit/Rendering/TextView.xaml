<!-- Uno equivalent of avalonedit/ICSharpCode.AvalonEdit/Rendering/TextView.xaml
     Keep in sync with the WPF version when making structural changes. -->
<UserControl x:Class="UnoEdit.Skia.Desktop.Controls.TextView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:UnoEdit.Skia.Desktop.Controls"
             KeyDown="OnRootKeyDown"
             PointerPressed="OnRootPointerPressed"
             PointerMoved="OnRootPointerMoved"
             PointerReleased="OnRootPointerReleased">
  <!--
    Background="#01000000" = nearly transparent but still hit-testable in Uno Skia.
    Pure Transparent receives no pointer events in Skia renderer.
    Keyboard events and pointer events are all on the UserControl so that
    CapturePointer / ReleasePointerCapture happen on the same element that
    receives the captured PointerReleased event.
  -->
  <Border x:Name="RootBorder"
          Background="#01000000"
          IsTabStop="True"
          AutomationProperties.Name="Code editor"
          AutomationProperties.AutomationId="CodeEditorBorder">
    <ScrollViewer x:Name="TextScrollViewer"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto"
                  ViewChanged="OnScrollViewerViewChanged">
      <StackPanel x:Name="ContentStackPanel"
                  VerticalAlignment="Top">
        <Border x:Name="TopSpacer" Height="0" />

        <Grid x:Name="EditorGrid">
          <Grid.ColumnDefinitions>
            <!--
              LineNumberColumn: shown/hidden by ShowLineNumbers.
              FoldMarginColumn: always visible (mirrors AvalonEdit where FoldingMargin
                                stays in LeftMargins independently of ShowLineNumbers).
              TextColumn: text content with a small left gap.
            -->
            <ColumnDefinition x:Name="LineNumberColumn" Width="Auto" />
            <ColumnDefinition x:Name="FoldMarginColumn" Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <!--
            Line-number margin.
            Visibility toggled by ShowLineNumbers in code-behind.
            Width=40 to fit right-aligned line numbers.
          -->
          <ItemsControl x:Name="LineNumberItemsControl" Width="40">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid Height="{StaticResource UnoEditorLineHeight}">
                  <!-- Line highlight in margin -->
                  <Border Background="{Binding LineHighlightBrush}"
                          Opacity="{Binding HighlightOpacity}" />
                  <TextBlock Text="{Binding Number}"
                             FontSize="{StaticResource UnoEditorTextFontSize}"
                             HorizontalTextAlignment="Right"
                             Foreground="{Binding GutterForegroundBrush}"
                             Padding="0,0,2,0"
                             VerticalAlignment="Center" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!--
            Fold-marker margin. Always visible regardless of ShowLineNumbers.
            Width=16 for the fold glyph.
          -->
          <ItemsControl x:Name="FoldMarginItemsControl" Grid.Column="1" Width="16">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid Height="{StaticResource UnoEditorLineHeight}">
                  <!-- Line highlight in margin -->
                  <Border Background="{Binding LineHighlightBrush}"
                          Opacity="{Binding HighlightOpacity}" />
                  <TextBlock Text="{Binding FoldMarkerGlyph}"
                             FontSize="{StaticResource UnoEditorGlyphFontSize}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Foreground="{Binding GutterForegroundBrush}"
                             AutomationProperties.Name="{Binding FoldMarkerAutomationName}"
                             PointerPressed="OnFoldGlyphPointerPressed"
                             IsHitTestVisible="True" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Text content column -->
          <Grid Grid.Column="2">
            <ItemsControl x:Name="LinesItemsControl">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <!--
                  x:DataType is intentionally omitted: all bindings below use classic {Binding}
                  (reflection-based), which is more reliable in Uno Platform Skia than compiled
                  x:Bind. Adding x:DataType here would trigger compiled-binding code generation
                  against a type that was previously co-located in the code-behind, causing
                  silent binding failures in the Skia renderer.
                -->
                <DataTemplate>
                  <Grid Height="{StaticResource UnoEditorLineHeight}">
                    <!-- Line highlight (current-line background) -->
                    <Border Background="{Binding LineHighlightBrush}"
                            Opacity="{Binding HighlightOpacity}" />

                    <!-- Text -->
                    <local:HighlightedTextBlock ViewModel="{Binding}"
                                                FontSize="{StaticResource UnoEditorTextFontSize}"
                                                VerticalAlignment="Center" />

                    <!-- Selection highlight -->
                    <Border Height="{StaticResource UnoEditorOverlayHeight}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Background="{Binding SelectionBrush}"
                            BorderBrush="{Binding SelectionBorderBrush}"
                            BorderThickness="{Binding SelectionBorderThickness}"
                            CornerRadius="{Binding SelectionCornerRadius}"
                            Margin="{Binding SelectionMargin}"
                            Width="{Binding SelectionWidth}"
                            Opacity="{Binding SelectionOpacity}" />

                    <!-- Explicit IME preedit underline for Uno/Skia -->
                    <Border Height="1.5"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom"
                            Background="{Binding PreeditUnderlineBrush}"
                            Margin="{Binding PreeditUnderlineMargin}"
                            Width="{Binding PreeditUnderlineWidth}"
                            Opacity="{Binding PreeditUnderlineOpacity}" />

                    <!-- Caret -->
                    <Border Width="{StaticResource UnoEditorCaretWidth}"
                            Height="{StaticResource UnoEditorOverlayHeight}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Background="{Binding CaretBrush}"
                            Margin="{Binding CaretMargin}"
                            Opacity="{Binding CaretOpacity}" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Overlay for inline UIElements created by InlineObjectRun -->
            <Canvas x:Name="InlineObjectsCanvas" IsHitTestVisible="True" />
          </Grid>
        </Grid>

        <Border x:Name="BottomSpacer" Height="0" />

        <!-- Live-region announcer for screen readers: updates when folds toggle -->
        <TextBlock x:Name="LiveRegionAnnouncer"
                   Opacity="0"
                   IsHitTestVisible="False"
                   AutomationProperties.AutomationId="LiveRegionAnnouncer" />
      </StackPanel>
    </ScrollViewer>
  </Border>
</UserControl>
