<!-- Uno equivalent of avalonedit/ICSharpCode.AvalonEdit/Search/SearchPanel.xaml
     Keep in sync with the WPF version when making structural changes. -->
<UserControl x:Class="UnoEdit.Skia.Desktop.Controls.SearchPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border x:Name="RootBorder"
          Margin="{StaticResource UnoSearchPanelMargin}"
          Padding="{StaticResource UnoSearchPanelPadding}"
          CornerRadius="{StaticResource UnoSearchPanelCornerRadius}"
          BorderThickness="{StaticResource UnoTextEditorBorderThickness}"
          Background="{StaticResource UnoSearchPanelBackgroundBrush}"
          BorderBrush="{StaticResource UnoSearchPanelBorderBrush}">
    <Grid ColumnSpacing="8" RowSpacing="8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="2*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <TextBox x:Name="SearchTextBox"
               Grid.Column="0"
               Header="Find"
               PlaceholderText="Search in document"
               TextChanged="OnSearchTextChanged"
               KeyDown="OnSearchTextBoxKeyDown" />

      <Button x:Name="PreviousButton"
              Grid.Column="1"
              Style="{StaticResource UnoSearchActionButtonStyle}"
              Click="OnPreviousClick"
              Content="↑" />
      <Button x:Name="NextButton"
              Grid.Column="2"
              Style="{StaticResource UnoSearchActionButtonStyle}"
              Click="OnNextClick"
              Content="↓" />
      <Button x:Name="CloseButton"
              Grid.Column="4"
              Style="{StaticResource UnoSearchActionButtonStyle}"
              Click="OnCloseClick"
              Content="✕" />

      <CheckBox x:Name="MatchCaseCheckBox"
                Grid.Row="1"
                Grid.Column="0"
                Style="{StaticResource UnoSearchOptionCheckBoxStyle}"
                Content="Match case"
                Checked="OnOptionChanged"
                Unchecked="OnOptionChanged" />
      <CheckBox x:Name="WholeWordsCheckBox"
                Grid.Row="1"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Style="{StaticResource UnoSearchOptionCheckBoxStyle}"
                Content="Whole words"
                Checked="OnOptionChanged"
                Unchecked="OnOptionChanged" />
      <CheckBox x:Name="UseRegexCheckBox"
                Grid.Row="1"
                Grid.Column="3"
                Style="{StaticResource UnoSearchOptionCheckBoxStyle}"
                Content="Regex"
                Checked="OnOptionChanged"
                Unchecked="OnOptionChanged" />
      <TextBlock x:Name="ResultsTextBlock"
                 Grid.Row="1"
                 Grid.Column="4"
                 Foreground="{StaticResource UnoSearchPanelResultsBrush}"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Right"
                 Text="No results" />
    </Grid>
  </Border>
</UserControl>
