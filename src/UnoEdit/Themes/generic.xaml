<!-- Uno equivalent of avalonedit/ICSharpCode.AvalonEdit/themes/generic.xaml
     Keep in sync with the WPF version when making structural changes. -->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Thickness x:Key="UnoTextEditorBorderThickness">1</Thickness>
  <CornerRadius x:Key="UnoTextEditorCornerRadius">10</CornerRadius>
  <CornerRadius x:Key="UnoSearchPanelCornerRadius">8</CornerRadius>
  <Thickness x:Key="UnoSearchPanelMargin">12,12,12,0</Thickness>
  <Thickness x:Key="UnoSearchPanelPadding">10</Thickness>
  <x:Double x:Key="UnoEditorLineHeight">22</x:Double>
  <x:Double x:Key="UnoEditorTextFontSize">13</x:Double>
  <x:Double x:Key="UnoEditorGlyphFontSize">10</x:Double>
  <x:Double x:Key="UnoEditorOverlayHeight">16</x:Double>
  <x:Double x:Key="UnoEditorCaretWidth">2</x:Double>

  <SolidColorBrush x:Key="UnoEditorBackgroundBrush" Color="#111827" />
  <SolidColorBrush x:Key="UnoEditorBorderBrush" Color="#334155" />
  <SolidColorBrush x:Key="UnoEditorTitleBarBackgroundBrush" Color="#0F172A" />
  <SolidColorBrush x:Key="UnoEditorTitleBarForegroundBrush" Color="#E5E7EB" />
  <SolidColorBrush x:Key="UnoEditorSummaryForegroundBrush" Color="#94A3B8" />
  <SolidColorBrush x:Key="UnoEditorGutterForegroundBrush" Color="#64748B" />
  <SolidColorBrush x:Key="UnoSearchPanelBackgroundBrush" Color="#172033" />
  <SolidColorBrush x:Key="UnoSearchPanelBorderBrush" Color="#334155" />
  <SolidColorBrush x:Key="UnoSearchPanelResultsBrush" Color="#94A3B8" />

  <Style x:Key="UnoSearchActionButtonStyle" TargetType="Button">
    <Setter Property="MinWidth" Value="44" />
    <Setter Property="MinHeight" Value="32" />
  </Style>

  <Style x:Key="UnoSearchOptionCheckBoxStyle" TargetType="CheckBox">
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Margin" Value="0,2,0,0" />
  </Style>
</ResourceDictionary>
