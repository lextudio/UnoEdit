  <ItemGroup Condition="'$(TargetFramework)' == 'net9.0-desktop' AND '$(UseNuGetPackage)' != 'true'">
    <ProjectReference Include="..\..\external\coretext\src\LeXtudio.UI.Text.Core.csproj" />
  </ItemGroup>

  <!-- Import native asset targets for project references (NuGet packages import via buildTransitive) -->
  <Import Project="../../external/coretext/src/buildTransitive/LeXtudio.UI.Text.Core.targets" Condition="'$(UseNuGetPackage)' != 'true'" />

  <ItemGroup Condition="'$(TargetFramework)' == 'net9.0-desktop' AND '$(UseNuGetPackage)' == 'true'">
    <PackageReference Include="LeXtudio.UI.Text.Core" />
  </ItemGroup>

  <!-- WinUI-specific package references and pages (only for the windows TargetFramework) -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net9.0-windows10.0.19041.0'">
    <PackageReference Include="Microsoft.WindowsAppSDK" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions"/>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
  </ItemGroup>

  <!-- Copy native assets from LeXtudio.UI.Text.Core to runtime directories for distribution to consumers (macOS osx-arm64 and osx-x64 RIDs only) -->
  <Target Name="CopyNativeTextCoreAssets"
          AfterTargets="Build"
          Condition="'$(OS)' == 'Unix' and Exists('/System/Library/Frameworks/AppKit.framework') and ('$(RuntimeIdentifier)' == 'osx-arm64' or '$(RuntimeIdentifier)' == 'osx-x64' or '$(RuntimeIdentifier)' == '') and '$(UseNuGetPackage)' != 'true'">
    <ItemGroup>
      <NativeTextCoreAssets Include="../../external/coretext/src/bin/$(Configuration)/net9.0-desktop/libUnoEditMacInput.dylib" />
    </ItemGroup>

    <Copy SourceFiles="@(NativeTextCoreAssets)"
          DestinationFolder="$(OutputPath)runtimes/osx-arm64/native/"
          SkipUnchangedFiles="true"
          Condition="'@(NativeTextCoreAssets)' != '' and '$(Configuration)' != ''">
      <Output TaskParameter="DestinationFiles" ItemName="CopiedNativeAssets" />
    </Copy>

    <Copy SourceFiles="@(NativeTextCoreAssets)"
          DestinationFolder="$(OutputPath)runtimes/osx-x64/native/"
          SkipUnchangedFiles="true"
          Condition="'@(NativeTextCoreAssets)' != '' and '$(Configuration)' != ''">
      <Output TaskParameter="DestinationFiles" ItemName="CopiedNativeAssets" />
    </Copy>

    <Message Importance="low"
             Text="[UnoEdit] Copied native text core assets: @(CopiedNativeAssets)"
             Condition="'@(CopiedNativeAssets)' != ''" />
  </Target>

  <!-- Declare native assets as content for project reference distribution (macOS only) -->
  <Target Name="IncludeNativeTextCoreContent"
          BeforeTargets="GetCopyToOutputDirectoryItems"
          Condition="'$(OS)' == 'Unix' and Exists('/System/Library/Frameworks/AppKit.framework') and '$(UseNuGetPackage)' != 'true'">
    <ItemGroup>
      <ContentWithTargetPath Include="$(OutputPath)runtimes/osx-arm64/native/libUnoEditMacInput.dylib"
                             Condition="Exists('$(OutputPath)runtimes/osx-arm64/native/libUnoEditMacInput.dylib')">
        <TargetPath>runtimes/osx-arm64/native/libUnoEditMacInput.dylib</TargetPath>
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        <Visible>false</Visible>
      </ContentWithTargetPath>
      <ContentWithTargetPath Include="$(OutputPath)runtimes/osx-x64/native/libUnoEditMacInput.dylib"
                             Condition="Exists('$(OutputPath)runtimes/osx-x64/native/libUnoEditMacInput.dylib')">
        <TargetPath>runtimes/osx-x64/native/libUnoEditMacInput.dylib</TargetPath>
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        <Visible>false</Visible>
      </ContentWithTargetPath>
    </ItemGroup>
  </Target>

  <ItemGroup Condition="'$(TargetFramework)' == 'net9.0-windows10.0.19041.0'">
