<Project Sdk="Uno.Sdk">
  <PropertyGroup>
    <!-- Detect Windows at MSBuild time and only include the Windows TFM on Windows hosts.
         On macOS/Linux this will leave the project targeting only net9.0-desktop so
         WinUI/Windows-only targets won't be attempted. -->
    <TargetFrameworks>net9.0-desktop</TargetFrameworks>
    <TargetFrameworks Condition="'$(OS)' == 'Windows_NT'">$(TargetFrameworks);net9.0-windows10.0.19041.0</TargetFrameworks>
    <!-- Support building for all RIDs to ensure native assets are properly handled -->
    <RuntimeIdentifiers>win-x64;win-arm64;linux-x64;linux-arm64;osx-arm64;osx-x64</RuntimeIdentifiers>
    <AssemblyName>UnoEdit</AssemblyName>
    <RootNamespace>ICSharpCode.AvalonEdit</RootNamespace>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <LangVersion>latest</LangVersion>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <EnableDefaultPageItems>false</EnableDefaultPageItems>
    <EnableDefaultUnoItems>false</EnableDefaultUnoItems>
    <NoWarn>$(NoWarn);1574;1591;8632;UNO0006</NoWarn>
    <UseNuGetPackage>true</UseNuGetPackage>
    
    <!-- NuGet package metadata -->
    <PackageId>LeXtudio.UnoEdit</PackageId>
    <Authors>LeXtudio</Authors>
    <Company>LeXtudio</Company>
    <Description>UnoEdit — a cross-platform text editor component (AvalonEdit) for Uno Platform and WinUI 3.</Description>
    <PackageTags>editor;text;avalonedit;uno;lextudio</PackageTags>
    <RepositoryType>git</RepositoryType>
    <RepositoryUrl>https://github.com/LeXtudio/UnoEdit</RepositoryUrl>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageIcon>logo.png</PackageIcon>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <IsPackable>true</IsPackable>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="" />
    <None Include="..\..\LICENSE" Pack="true" PackagePath="" />
    <None Include="..\..\THIRD_PARTY_NOTICES.md" Pack="true" PackagePath="" />
    <None Include="..\..\avalonedit\LICENSE" Pack="true" PackagePath="licenses/avalonedit_LICENSE.txt" />
    <None Include="..\..\images\logo.png" Pack="true" PackagePath="" />
  </ItemGroup>

  <!-- WinUI / Windows-specific properties (only applied when building the windows target) -->
  <PropertyGroup Condition="'$(TargetFramework)' == 'net9.0-windows10.0.19041.0'">
    <UseWinUI>true</UseWinUI>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <DefineConstants>$(DefineConstants);WINDOWS_APP_SDK</DefineConstants>
    <WindowsSdkPackageVersion>10.0.19041.57</WindowsSdkPackageVersion>
  </PropertyGroup>

