    <Page Include="Controls\TextEditor.xaml" />
    <Compile Include="Controls\TextEditor.xaml.cs">
      <DependentUpon>TextEditor.xaml</DependentUpon>
    </Compile>
    <Compile Include="Controls\TextAreaProxy.cs" />
  </ItemGroup>

